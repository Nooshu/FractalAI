{
  "name": "fractalai",
  "version": "6.1.7",
  "description": "A web-based fractal generator using regl and WebGL",
  "license": "CC-BY-4.0",
  "type": "module",
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "node scripts/generate-presets-manifest.js && vite",
    "build": "node scripts/generate-presets-manifest.js && NODE_ENV=production npx vite build && NODE_ENV=production node scripts/compress-brotli.js",
    "build:prod": "NODE_ENV=production node scripts/generate-presets-manifest.js && NODE_ENV=production vite build && NODE_ENV=production node scripts/compress-brotli.js",
    "preview": "vite preview",
    "generate-manifest": "node scripts/generate-presets-manifest.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,css,html,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,css,html,md}\"",
    "stylelint": "stylelint \"**/*.css\"",
    "stylelint:fix": "stylelint \"**/*.css\" --fix",
    "check": "npm run lint && npm run format:check && npm run stylelint",
    "check:all": "npm run test && npm run lint && npm run stylelint",
    "verify": "npm ci && npm audit --audit-level=moderate",
    "audit": "npm audit",
    "test": "vitest",
    "test:unit": "vitest tests/unit",
    "test:watch": "vitest --watch",
    "test:visual": "FORCE_COLOR=0 playwright test",
    "test:visual:update": "FORCE_COLOR=0 playwright test --update-snapshots",
    "test:visual:ui": "FORCE_COLOR=0 playwright test --ui",
    "test:visual:report": "playwright show-report"
  },
  "dependencies": {
    "piexifjs": "1.0.6",
    "regl": "2.1.1",
    "synaptic": "1.1.4"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.2.1",
    "esbuild": "0.28.0",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "stylelint": "17.9.0",
    "stylelint-config-standard": "40.0.0",
    "vite": "^8.0.10",
    "vitest": "4.1.5"
  },
  "overrides": {
    "brace-expansion": "5.0.5",
    "flatted": "3.4.2",
    "picomatch": "4.0.4",
    "micromatch": {
      "picomatch": "4.0.4"
    },
    "ajv": "8.20.0",
    "eslint": {
      "ajv": "8.20.0"
    },
    "table": {
      "ajv": "8.20.0"
    }
  }
}
